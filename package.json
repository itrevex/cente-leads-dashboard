{
  "name": "cente-leads-dashboard",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:coverage": "COVERAGE=true astro build",
    "build:e2e": "E2E=true astro build",
    "build:e2e:coverage": "E2E=true COVERAGE=true astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint .",
    "prettier:fix": "prettier --write .",
    "prettier": "prettier --check .",
    "test": "vitest run",
    "test:unit:coverage": "mkdir -p .nyc_output && rm -f .nyc_output/vitest-coverage.json && COVERAGE=true VITEST_NYC_FILE=.nyc_output/vitest-coverage.json vitest run --fileParallelism=false",
    "test:e2e": "npm run build:e2e && playwright test",
    "test:e2e:coverage": "npm run build:e2e:coverage && COVERAGE=true playwright test && npm run test:unit:coverage && npm run coverage:report",
    "coverage:report": "rm -rf .nyc_merged && nyc merge .nyc_output .nyc_output/merged.json && mkdir -p .nyc_merged && cp .nyc_output/merged.json .nyc_merged/coverage.json && nyc report --reporter=text --reporter=html --reporter=json-summary -t .nyc_merged --check-coverage --lines 80 --branches 80",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/netlify": "^8.1.1",
    "@astrojs/react": "^6.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.3",
    "firebase": "^12.15.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@astrojs/node": "^11.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-istanbul": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "nyc": "^18.0.0",
    "prettier": "^3.8.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript-eslint": "^8.62.0",
    "vite-plugin-istanbul": "^9.0.1",
    "vitest": "^4.1.9"
  }
}
