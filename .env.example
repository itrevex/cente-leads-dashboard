# Copy to .env for local development. Never commit the real .env file.

# Base URL of the cente-leads-backend API (server-side only — never exposed
# to the browser, since all API calls happen in Astro middleware/API routes,
# not client-side fetches).
API_BASE_URL=http://localhost:8000/api/v1

# Set "true" only over HTTPS deployments — marks the auth cookie Secure.
# Leave "false" for local http://localhost dev.
COOKIE_SECURE=false

# Web Push (browser notifications). Client-side Firebase config values,
# not secrets — from Firebase console → Project settings → General →
# your web app's config, and → Cloud Messaging → Web Push certificates
# for the VAPID key.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_VAPID_KEY=
