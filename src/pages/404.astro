---
import AppLayout from '../shell/AppLayout.astro';
import { Compass } from 'lucide-react';
---

<AppLayout title="Page not found">
  <div
    class="flex flex-col items-center justify-center gap-4 rounded-md border border-ink-100 bg-white py-24 text-center dark:border-ink-700 dark:bg-ink-800"
  >
    <div
      class="flex h-16 w-16 items-center justify-center rounded-full bg-cente-blue-50 dark:bg-ink-700"
    >
      <Compass size={28} className="text-cente-blue-600 dark:text-cente-blue-300" />
    </div>
    <div>
      <p class="text-2xl font-bold text-ink-700 dark:text-ink-50">404</p>
      <p class="mt-1 text-sm font-medium text-ink-700 dark:text-ink-50">Page not found</p>
      <p class="mt-1 text-sm text-ink-400">
        The page you're looking for doesn't exist or may have moved.
      </p>
    </div>
    <a
      href="/"
      class="mt-2 rounded-pill bg-cente-blue-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-cente-red-600 mb-4"
    >
      Back to Overview
    </a>
  </div>
</AppLayout>
