---
import AppLayout from '../../../shell/AppLayout.astro';
import NotAuthorized from '../../../shell/NotAuthorized.astro';
import { ApiError } from '../../../shared/api-client';
import {
  getLead,
  getLoanProduct,
  getFormSchema,
  getChairApprovals,
  getComments,
  getDocuments,
  getLeadAuditEvents,
} from '../api';
import {
  STATUS_META,
  formatUgx,
  initialsOf,
  AUDIT_ACTION_LABELS,
  DOC_TYPE_LABELS,
  UPLOAD_STATUS_META,
} from '../presentation';
import Badge from '../../../shared/components/Badge';
import Avatar from '../../../shared/components/Avatar';
import LeadDecisionActions from '../components/LeadDecisionActions';
import AddCommentForm from '../components/AddCommentForm';
import ReassignLead from '../components/ReassignLead';

const { id } = Astro.params;
const accessToken = Astro.locals.accessToken;
const activeTab = Astro.url.searchParams.get('tab') ?? 'application';
const { user } = Astro.locals;

let forbidden = false;
let notFound = false;
let lead: Awaited<ReturnType<typeof getLead>> | null = null;
let product: Awaited<ReturnType<typeof getLoanProduct>> | null = null;
let formSchema: Awaited<ReturnType<typeof getFormSchema>> | null = null;
let chairApprovals: Awaited<ReturnType<typeof getChairApprovals>> = [];
let comments: Awaited<ReturnType<typeof getComments>> = [];
let documents: Awaited<ReturnType<typeof getDocuments>> = [];
let auditEvents: Awaited<ReturnType<typeof getLeadAuditEvents>> = [];

try {
  lead = await getLead(accessToken, id!);
  [product, formSchema, chairApprovals, comments, documents, auditEvents] = await Promise.all([
    getLoanProduct(accessToken, lead.loan_product),
    getFormSchema(accessToken, lead.form_schema),
    getChairApprovals(accessToken, lead.id),
    getComments(accessToken, lead.id),
    getDocuments(accessToken, lead.id),
    getLeadAuditEvents(accessToken, lead.id),
  ]);
} catch (err) {
  if (err instanceof ApiError && err.status === 403) {
    forbidden = true;
  } else if (err instanceof ApiError && err.status === 404) {
    notFound = true;
  } else {
    throw err;
  }
}

const fieldLabelByKey = new Map<string, string>();
const fieldTypeByKey = new Map<string, string>();
if (formSchema) {
  for (const step of formSchema.steps) {
    for (const field of step.form_fields) {
      fieldLabelByKey.set(field.key, field.label);
      fieldTypeByKey.set(field.key, field.field_type);
    }
  }
}

// file_upload answers hold a local_documents clientLocalId (see mobile's
// FieldInput/new.tsx file_upload capture flow), not a human-readable value --
// resolve it against the lead's documents list to link the actual file.
const documentByClientLocalId = new Map<string, (typeof documents)[number]>();
for (const doc of documents) {
  if (doc.client_local_id) {
    documentByClientLocalId.set(doc.client_local_id, doc);
  }
}

const latestChairApproval = chairApprovals[0] ?? null;
const internalComments = comments.filter((c) => c.is_internal);
const externalComments = comments.filter((c) => !c.is_internal);

function tabHref(tab: string): string {
  return `/leads/${id}?tab=${tab}`;
}

const statusMeta = lead
  ? (STATUS_META[lead.status] ?? { label: lead.status, color: 'neutral' })
  : null;

// Mirrors apps.leads.views.LeadRequestInfoView/LeadRecommendView/
// LeadDeclineView/LeadReturnToAgentView allowed_roles — only loan officers
// and the head of loans may act on a lead under bank review.
const canDecide =
  !!user && ['loan_officer', 'head_of_loans'].includes(user.role) && lead?.status === 'review';

// Mirrors apps.leads.views.LeadReassignView.allowed_roles (ADR-0020/0021).
// Available on any non-terminal lead, unlike canDecide which is review-only.
const TERMINAL_STATUSES = ['recommended', 'declined'];
const canReassign =
  !!user &&
  ['head_of_loans', 'compliance_officer', 'mcp_officer', 'system_admin'].includes(user.role) &&
  !!lead &&
  !TERMINAL_STATUSES.includes(lead.status);
---

<AppLayout title="Lead Detail">
  {
    forbidden || notFound || !lead || !statusMeta ? (
      <NotAuthorized
        message={
          notFound ? "This lead doesn't exist." : "You don't have permission to view this lead."
        }
      />
    ) : (
      <div>
        <a
          href="/leads"
          class="mb-3 inline-flex items-center gap-1 text-sm text-ink-500 hover:text-cente-blue-600 dark:text-ink-300"
        >
          ← Back to Leads
        </a>

        <div class="mb-6 flex flex-wrap items-start justify-between gap-4">
          <div class="flex items-center gap-3">
            <Avatar initials={initialsOf(lead.applicant_name)} />
            <div>
              <h1 class="text-2xl font-semibold text-ink-700 dark:text-ink-50">
                {lead.applicant_name}
              </h1>
              <div class="mt-1 flex flex-wrap items-center gap-3 text-xs text-ink-400">
                <span class="inline-flex items-center gap-1">
                  {lead.id.slice(0, 8)}
                  <button
                    type="button"
                    class="copy-lead-id-btn cursor-pointer rounded p-0.5 text-ink-400 hover:text-cente-blue-600"
                    data-lead-id={lead.id}
                    title="Copy full lead ID"
                    aria-label="Copy full lead ID"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      class="copy-icon h-3.5 w-3.5"
                    >
                      <path d="M7 3a1 1 0 0 0-1 1v1H5a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h7a2 2 0 0 0 2-2v-1h1a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-2V3a1 1 0 0 0-1-1H7Zm5 3V4H8v2h4Zm-7 2h7v9H5V8Zm9 0h1v7h-1V8Z" />
                    </svg>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      class="check-icon hidden h-3.5 w-3.5 text-success"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  </button>
                </span>
                <span>{lead.applicant_phone}</span>
                <span>{lead.branch_name}</span>
                <span>{lead.created_at.slice(0, 10)}</span>
              </div>
            </div>
          </div>
          <div class="flex items-center gap-3">
            {canReassign && (
              <ReassignLead
                leadId={lead.id}
                assignedAgentId={lead.assigned_agent}
                reviewingOfficerId={lead.reviewing_officer}
                client:load
              />
            )}
            <Badge label={statusMeta.label} color={statusMeta.color} />
          </div>
        </div>

        {canDecide && (
          <div class="mb-6 rounded-md border border-ink-100 bg-white p-4 dark:border-ink-700 dark:bg-ink-800">
            <h3 class="mb-3 text-sm font-semibold text-ink-700 dark:text-ink-50">
              Bank Review Decision
            </h3>
            <LeadDecisionActions leadId={lead.id} client:load />
          </div>
        )}

        <div class="mb-4 grid grid-cols-1 gap-4 md:grid-cols-3">
          <div class="rounded-md border border-ink-100 bg-white dark:border-ink-700 dark:bg-ink-800">
            <div class="border-b border-ink-100 px-5 py-3 dark:border-ink-700">
              <h3 class="text-sm font-semibold text-ink-700 dark:text-ink-50">
                Agent &amp; Source
              </h3>
            </div>
            <dl class="space-y-2 p-5 text-sm">
              <div class="flex justify-between gap-3">
                <dt class="text-ink-400">Captured by</dt>
                <dd class="text-right text-ink-700 dark:text-ink-50">
                  {lead.assigned_agent_name ?? 'Branch walk-in'}
                </dd>
              </div>
              <div class="flex justify-between gap-3">
                <dt class="text-ink-400">Reviewing officer</dt>
                <dd class="text-right text-ink-700 dark:text-ink-50">
                  {lead.reviewing_officer_name ?? 'Unassigned'}
                </dd>
              </div>
              <div class="flex justify-between gap-3">
                <dt class="text-ink-400">Source</dt>
                <dd class="text-right text-ink-700 dark:text-ink-50">{lead.source_label}</dd>
              </div>
              {lead.cooperative_name && (
                <div class="flex justify-between gap-3">
                  <dt class="text-ink-400">Cooperative</dt>
                  <dd class="text-right text-ink-700 dark:text-ink-50">{lead.cooperative_name}</dd>
                </div>
              )}
              <div class="flex justify-between gap-3">
                <dt class="text-ink-400">Captured on</dt>
                <dd class="text-right text-ink-700 dark:text-ink-50">
                  {lead.created_at.slice(0, 10)}
                </dd>
              </div>
            </dl>
          </div>

          <div class="rounded-md border border-ink-100 bg-white dark:border-ink-700 dark:bg-ink-800">
            <div class="border-b border-ink-100 px-5 py-3 dark:border-ink-700">
              <h3 class="text-sm font-semibold text-ink-700 dark:text-ink-50">
                Chair Approval
                {latestChairApproval
                  ? ` · ${latestChairApproval.decision}`
                  : lead.cooperative
                    ? ' · Pending'
                    : ' · Not Applicable'}
              </h3>
            </div>
            <div class="p-5 text-sm">
              {latestChairApproval ? (
                <dl class="space-y-2">
                  <div class="flex justify-between gap-3">
                    <dt class="text-ink-400">
                      {latestChairApproval.decision === 'endorsed' ? 'Signed by' : 'Rejected by'}
                    </dt>
                    <dd class="text-right text-ink-700 dark:text-ink-50">
                      {latestChairApproval.chairperson_name}
                    </dd>
                  </div>
                  <div class="flex justify-between gap-3">
                    <dt class="text-ink-400">Signed at</dt>
                    <dd class="text-right text-ink-700 dark:text-ink-50">
                      {latestChairApproval.signed_at.slice(0, 16).replace('T', ' ')}
                    </dd>
                  </div>
                  {latestChairApproval.note && (
                    <div class="flex justify-between gap-3">
                      <dt class="text-ink-400">Note</dt>
                      <dd class="text-right text-ink-700 dark:text-ink-50">
                        "{latestChairApproval.note}"
                      </dd>
                    </div>
                  )}
                </dl>
              ) : lead.cooperative ? (
                <p class="text-ink-400">
                  Waiting for cooperative chairperson to review and sign with their PIN.
                </p>
              ) : (
                <p class="text-ink-400">
                  This lead has no cooperative — it skips chair approval and goes straight to bank
                  review.
                </p>
              )}
            </div>
          </div>

          <div class="rounded-md border border-ink-100 bg-white dark:border-ink-700 dark:bg-ink-800">
            <div class="border-b border-ink-100 px-5 py-3 dark:border-ink-700">
              <h3 class="text-sm font-semibold text-ink-700 dark:text-ink-50">
                Lifecycle Timeline
              </h3>
            </div>
            <div class="p-5">
              {auditEvents.length === 0 ? (
                <p class="text-sm text-ink-400">No event history available for this lead.</p>
              ) : (
                <div class="space-y-2 text-xs">
                  {auditEvents
                    .slice()
                    .reverse()
                    .map((event) => (
                      <div class="space-y-0.5">
                        <div class="flex items-center gap-2 text-ink-700 dark:text-ink-50">
                          <span class="font-semibold text-success">✓</span>
                          <span class="flex-1">
                            {AUDIT_ACTION_LABELS[event.action] ?? event.action}
                          </span>
                          <span class="text-ink-400">{event.occurred_at.slice(11, 16)}</span>
                        </div>
                        {event.reason ? <p class="pl-5 text-ink-400">{event.reason}</p> : null}
                      </div>
                    ))}
                </div>
              )}
            </div>
          </div>
        </div>

        <div class="rounded-md border border-ink-100 bg-white dark:border-ink-700 dark:bg-ink-800">
          <div class="flex gap-1 border-b border-ink-100 px-3 dark:border-ink-700">
            <a
              href={tabHref('application')}
              class={`px-4 py-3 text-sm font-medium ${
                activeTab === 'application'
                  ? 'border-b-2 border-cente-blue-600 text-cente-blue-600'
                  : 'text-ink-500 dark:text-ink-300'
              }`}
            >
              Application
            </a>
            <a
              href={tabHref('documents')}
              class={`px-4 py-3 text-sm font-medium ${
                activeTab === 'documents'
                  ? 'border-b-2 border-cente-blue-600 text-cente-blue-600'
                  : 'text-ink-500 dark:text-ink-300'
              }`}
            >
              Documents <span class="text-xs text-ink-400">{documents.length}</span>
            </a>
            <a
              href={tabHref('comments')}
              class={`px-4 py-3 text-sm font-medium ${
                activeTab === 'comments'
                  ? 'border-b-2 border-cente-blue-600 text-cente-blue-600'
                  : 'text-ink-500 dark:text-ink-300'
              }`}
            >
              Comments <span class="text-xs text-ink-400">{comments.length}</span>
            </a>
            <a
              href={tabHref('timeline')}
              class={`px-4 py-3 text-sm font-medium ${
                activeTab === 'timeline'
                  ? 'border-b-2 border-cente-blue-600 text-cente-blue-600'
                  : 'text-ink-500 dark:text-ink-300'
              }`}
            >
              Timeline
            </a>
          </div>

          {activeTab === 'application' && (
            <div class="grid grid-cols-1 gap-8 p-5 md:grid-cols-2">
              <div>
                <h4 class="mb-3 text-xs font-semibold uppercase tracking-wide text-ink-400">
                  Loan Request
                </h4>
                <dl class="space-y-2 text-sm">
                  <div class="flex justify-between gap-3">
                    <dt class="text-ink-400">Product</dt>
                    <dd class="text-right text-ink-700 dark:text-ink-50">
                      {product ? `${product.name} (${product.code})` : '-'}
                    </dd>
                  </div>
                  <div class="flex justify-between gap-3">
                    <dt class="text-ink-400">Amount</dt>
                    <dd class="text-right font-semibold text-ink-700 dark:text-ink-50">
                      {formatUgx(lead.amount_requested)}
                    </dd>
                  </div>
                  <div class="flex justify-between gap-3">
                    <dt class="text-ink-400">Term</dt>
                    <dd class="text-right text-ink-700 dark:text-ink-50">
                      {lead.term_months} months
                    </dd>
                  </div>
                  <div class="flex justify-between gap-3">
                    <dt class="text-ink-400">Interest rate</dt>
                    <dd class="text-right text-ink-700 dark:text-ink-50">
                      {product ? `${(product.interest_rate_bps / 100).toFixed(2)}%` : '-'}
                    </dd>
                  </div>
                  {lead.purpose && (
                    <div class="flex justify-between gap-3">
                      <dt class="text-ink-400">Purpose</dt>
                      <dd class="text-right text-ink-700 dark:text-ink-50">{lead.purpose}</dd>
                    </div>
                  )}
                </dl>
              </div>
              <div>
                <h4 class="mb-3 text-xs font-semibold uppercase tracking-wide text-ink-400">
                  Form Answers
                </h4>
                {Object.keys(lead.form_answers).length === 0 ? (
                  <p class="text-sm text-ink-400">No form answers recorded.</p>
                ) : (
                  <dl class="space-y-2 text-sm">
                    {Object.entries(lead.form_answers).map(([key, value]) => {
                      const isFileUpload = fieldTypeByKey.get(key) === 'file_upload';
                      const linkedDoc = isFileUpload
                        ? documentByClientLocalId.get(String(value))
                        : undefined;
                      return (
                        <div class="flex justify-between gap-3">
                          <dt class="text-ink-400">{fieldLabelByKey.get(key) ?? key}</dt>
                          <dd class="text-right text-ink-700 dark:text-ink-50">
                            {isFileUpload ? (
                              linkedDoc?.download_url ? (
                                <a
                                  href={linkedDoc.download_url}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                  class="text-brand-600 underline"
                                >
                                  {DOC_TYPE_LABELS[linkedDoc.doc_type] ?? 'View file'}
                                </a>
                              ) : linkedDoc ? (
                                <span>
                                  {DOC_TYPE_LABELS[linkedDoc.doc_type] ?? 'File'} (uploading…)
                                </span>
                              ) : (
                                <span class="text-ink-400">Attached on device, not yet synced</span>
                              )
                            ) : (
                              String(value)
                            )}
                          </dd>
                        </div>
                      );
                    })}
                  </dl>
                )}
              </div>
            </div>
          )}

          {activeTab === 'documents' && (
            <div class="p-5">
              {documents.length === 0 ? (
                <p class="text-sm text-ink-400">No documents uploaded yet.</p>
              ) : (
                <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                  {documents.map((doc) => {
                    const meta = UPLOAD_STATUS_META[doc.upload_status] ?? {
                      label: doc.upload_status,
                      color: 'neutral',
                    };
                    return (
                      <div class="flex items-center justify-between gap-3 rounded-sm border border-ink-100 px-4 py-3 dark:border-ink-700">
                        <div>
                          <p class="text-sm font-medium text-ink-700 dark:text-ink-50">
                            {DOC_TYPE_LABELS[doc.doc_type] ?? doc.doc_type}
                          </p>
                          <p class="text-xs text-ink-400">
                            {doc.size_bytes ? `${Math.round(doc.size_bytes / 1024)} KB` : '—'}
                          </p>
                        </div>
                        <Badge label={meta.label} color={meta.color} />
                      </div>
                    );
                  })}
                </div>
              )}
            </div>
          )}

          {activeTab === 'comments' && (
            <div class="space-y-4 p-5">
              <AddCommentForm leadId={lead.id} client:load />
              {comments.length === 0 ? (
                <p class="text-sm text-ink-400">No comments yet.</p>
              ) : (
                comments.map((comment) => (
                  <div class="flex gap-3">
                    <Avatar initials={initialsOf(comment.author_name)} />
                    <div class="flex-1 rounded-sm bg-ink-50 px-4 py-3 dark:bg-ink-900">
                      <div class="flex items-center justify-between gap-2">
                        <strong class="text-sm text-ink-700 dark:text-ink-50">
                          {comment.author_name}
                        </strong>
                        <span class="text-xs text-ink-400">
                          {comment.created_at.slice(0, 16).replace('T', ' ')}
                          {comment.is_internal && ' · Internal'}
                        </span>
                      </div>
                      <p class="mt-1 text-sm text-ink-600 dark:text-ink-200">{comment.body}</p>
                    </div>
                  </div>
                ))
              )}
              <p class="text-xs text-ink-400">
                {internalComments.length} internal · {externalComments.length} external
              </p>
            </div>
          )}

          {activeTab === 'timeline' && (
            <div class="p-5">
              {auditEvents.length === 0 ? (
                <p class="text-sm text-ink-400">
                  No event history available — this view requires audit-log access.
                </p>
              ) : (
                <div class="space-y-4">
                  {auditEvents.map((event) => (
                    <div class="flex gap-3 border-b border-ink-100 pb-3 last:border-b-0 dark:border-ink-700">
                      <div class="flex-1">
                        <p class="text-sm font-medium text-ink-700 dark:text-ink-50">
                          {AUDIT_ACTION_LABELS[event.action] ?? event.action}
                        </p>
                        <p class="text-xs text-ink-400">
                          {event.actor_role || 'System'}
                          {event.reason && ` · ${event.reason}`}
                        </p>
                      </div>
                      <span class="text-xs text-ink-400">
                        {event.occurred_at.slice(0, 16).replace('T', ' ')}
                      </span>
                    </div>
                  ))}
                </div>
              )}
            </div>
          )}
        </div>
      </div>
    )
  }
</AppLayout>

<script>
  document.querySelectorAll('.copy-lead-id-btn').forEach((el) => {
    const button = el as HTMLButtonElement;
    button.addEventListener('click', async () => {
      const leadId = button.dataset.leadId;
      if (!leadId) return;
      await navigator.clipboard.writeText(leadId);

      const copyIcon = button.querySelector('.copy-icon');
      const checkIcon = button.querySelector('.check-icon');
      copyIcon?.classList.add('hidden');
      checkIcon?.classList.remove('hidden');
      setTimeout(() => {
        copyIcon?.classList.remove('hidden');
        checkIcon?.classList.add('hidden');
      }, 3000);
    });
  });
</script>
