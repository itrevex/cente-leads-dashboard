---
import AppLayout from '../../../shell/AppLayout.astro';
import NotAuthorized from '../../../shell/NotAuthorized.astro';
import { ApiError } from '../../../shared/api-client';
import { getLeads, getBranchOptions, getCooperativeOptions, getAgentOptions } from '../api';
import { STATUS_META, formatUgx, initialsOf } from '../../../shared/lead-presentation';
import { STATUS_FILTER_OPTIONS, SOURCE_FILTER_OPTIONS } from '../presentation';
import Badge from '../../../shared/components/Badge';
import Avatar from '../../../shared/components/Avatar';
import type { Lead, LeadFilters, PaginatedResponse } from '../types';

const { user } = Astro.locals;
const accessToken = Astro.locals.accessToken;
const params = Astro.url.searchParams;

const PAGE_SIZE = 25;
const page = Math.max(1, parseInt(params.get('page') ?? '1', 10) || 1);

const filters: LeadFilters = {
  status: params.get('status') ?? undefined,
  branch: params.get('branch') ?? undefined,
  cooperative: params.get('cooperative') ?? undefined,
  assigned_agent: params.get('assigned_agent') ?? undefined,
  source: params.get('source') ?? undefined,
  search: params.get('search') ?? undefined,
  created_from: params.get('created_from') ?? undefined,
  created_to: params.get('created_to') ?? undefined,
  limit: PAGE_SIZE,
  offset: (page - 1) * PAGE_SIZE,
};

let leadsPage: PaginatedResponse<Lead> | null = null;
let branchOptions: { id: string; name: string }[] = [];
let cooperativeOptions: { id: string; name: string }[] = [];
let agentOptions: { id: string; full_name: string }[] = [];
let forbidden = false;

try {
  [leadsPage, branchOptions, cooperativeOptions, agentOptions] = await Promise.all([
    getLeads(accessToken, filters),
    getBranchOptions(accessToken),
    getCooperativeOptions(accessToken),
    getAgentOptions(accessToken),
  ]);
} catch (err) {
  if (err instanceof ApiError && err.status === 403) {
    forbidden = true;
  } else {
    throw err;
  }
}

const totalCount = leadsPage?.count ?? 0;
const totalPages = Math.max(1, Math.ceil(totalCount / PAGE_SIZE));

function pageHref(targetPage: number): string {
  const next = new URLSearchParams(params);
  next.set('page', String(targetPage));
  return `/leads?${next.toString()}`;
}

const scopeLabel = user.branch ? 'Branch scope' : 'All branches';
---

<AppLayout title="Leads">
  {
    forbidden || !leadsPage ? (
      <NotAuthorized message="You don't have permission to view leads." />
    ) : (
      <div>
        <div class="mb-6 flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-semibold text-cente-blue-600 dark:text-cente-blue-300">
              Leads
            </h1>
            <p class="mt-1 text-sm text-ink-500 dark:text-ink-300">
              {scopeLabel} · {totalCount} leads in scope
            </p>
          </div>
        </div>

        <form
          method="get"
          class="mb-4 flex flex-wrap items-end gap-3 rounded-md border border-ink-100 bg-white p-4 dark:border-ink-700 dark:bg-ink-800"
        >
          <div class="flex flex-col gap-1">
            <label for="search" class="text-xs font-medium text-ink-500 dark:text-ink-300">
              Search
            </label>
            <input
              id="search"
              name="search"
              type="text"
              placeholder="ID, applicant, NIN"
              value={params.get('search') ?? ''}
              class="w-56 rounded-sm border border-ink-200 px-3 py-2 text-sm dark:border-ink-600 dark:bg-ink-900"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label for="status" class="text-xs font-medium text-ink-500 dark:text-ink-300">
              Status
            </label>
            <select
              id="status"
              name="status"
              class="rounded-sm border border-ink-200 px-3 py-2 text-sm dark:border-ink-600 dark:bg-ink-900"
            >
              {STATUS_FILTER_OPTIONS.map((opt) => (
                <option value={opt.value} selected={params.get('status') === opt.value}>
                  {opt.label}
                </option>
              ))}
            </select>
          </div>

          <div class="flex flex-col gap-1">
            <label for="branch" class="text-xs font-medium text-ink-500 dark:text-ink-300">
              Branch
            </label>
            <select
              id="branch"
              name="branch"
              class="rounded-sm border border-ink-200 px-3 py-2 text-sm dark:border-ink-600 dark:bg-ink-900"
            >
              <option value="">All branches</option>
              {branchOptions.map((b) => (
                <option value={b.id} selected={params.get('branch') === b.id}>
                  {b.name}
                </option>
              ))}
            </select>
          </div>

          <div class="flex flex-col gap-1">
            <label for="cooperative" class="text-xs font-medium text-ink-500 dark:text-ink-300">
              Cooperative
            </label>
            <select
              id="cooperative"
              name="cooperative"
              class="rounded-sm border border-ink-200 px-3 py-2 text-sm dark:border-ink-600 dark:bg-ink-900"
            >
              <option value="">All cooperatives</option>
              {cooperativeOptions.map((c) => (
                <option value={c.id} selected={params.get('cooperative') === c.id}>
                  {c.name}
                </option>
              ))}
            </select>
          </div>

          <div class="flex flex-col gap-1">
            <label for="assigned_agent" class="text-xs font-medium text-ink-500 dark:text-ink-300">
              Agent
            </label>
            <select
              id="assigned_agent"
              name="assigned_agent"
              class="rounded-sm border border-ink-200 px-3 py-2 text-sm dark:border-ink-600 dark:bg-ink-900"
            >
              <option value="">All agents</option>
              {agentOptions.map((a) => (
                <option value={a.id} selected={params.get('assigned_agent') === a.id}>
                  {a.full_name}
                </option>
              ))}
            </select>
          </div>

          <div class="flex flex-col gap-1">
            <label for="source" class="text-xs font-medium text-ink-500 dark:text-ink-300">
              Source
            </label>
            <select
              id="source"
              name="source"
              class="rounded-sm border border-ink-200 px-3 py-2 text-sm dark:border-ink-600 dark:bg-ink-900"
            >
              {SOURCE_FILTER_OPTIONS.map((opt) => (
                <option value={opt.value} selected={params.get('source') === opt.value}>
                  {opt.label}
                </option>
              ))}
            </select>
          </div>

          <div class="flex flex-col gap-1">
            <label for="created_from" class="text-xs font-medium text-ink-500 dark:text-ink-300">
              From
            </label>
            <input
              id="created_from"
              name="created_from"
              type="date"
              value={params.get('created_from') ?? ''}
              class="rounded-sm border border-ink-200 px-3 py-2 text-sm dark:border-ink-600 dark:bg-ink-900"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label for="created_to" class="text-xs font-medium text-ink-500 dark:text-ink-300">
              To
            </label>
            <input
              id="created_to"
              name="created_to"
              type="date"
              value={params.get('created_to') ?? ''}
              class="rounded-sm border border-ink-200 px-3 py-2 text-sm dark:border-ink-600 dark:bg-ink-900"
            />
          </div>

          <div class="flex gap-2">
            <button
              type="submit"
              class="rounded-pill bg-cente-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-cente-red-600"
            >
              Apply
            </button>
            <a
              href="/leads"
              class="rounded-pill border border-ink-200 px-4 py-2 text-sm text-ink-600 hover:bg-ink-50 dark:border-ink-700 dark:text-ink-200 dark:hover:bg-ink-800"
            >
              Clear
            </a>
          </div>
        </form>

        <div class="rounded-md border border-ink-100 bg-white dark:border-ink-700 dark:bg-ink-800">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-xs text-ink-400">
                <th class="px-5 py-2 font-medium">Lead ID</th>
                <th class="px-2 py-2 font-medium">Applicant</th>
                <th class="px-2 py-2 font-medium">Source</th>
                <th class="px-2 py-2 font-medium">Cooperative</th>
                <th class="px-2 py-2 font-medium">Branch</th>
                <th class="px-2 py-2 font-medium">Stage</th>
                <th class="px-2 py-2 text-right font-medium">Amount</th>
                <th class="px-5 py-2 font-medium">Date</th>
              </tr>
            </thead>
            <tbody>
              {leadsPage.results.length === 0 && (
                <tr>
                  <td colspan={8} class="px-5 py-6 text-center text-ink-400">
                    No leads match these filters.
                  </td>
                </tr>
              )}
              {leadsPage.results.map((lead) => {
                const meta = STATUS_META[lead.status] ?? { label: lead.status, color: 'neutral' };
                return (
                  <tr class="border-t border-ink-100 hover:bg-ink-50 dark:border-ink-700 dark:hover:bg-ink-700/40">
                    <td class="px-5 py-3 font-mono text-xs text-ink-500 dark:text-ink-300">
                      {lead.id.slice(0, 8)}
                    </td>
                    <td class="px-2 py-3">
                      <div class="flex items-center gap-2.5">
                        <Avatar initials={initialsOf(lead.applicant_name)} />
                        <div>
                          <p class="font-medium text-ink-700 dark:text-ink-50">
                            {lead.applicant_name}
                          </p>
                          <p class="text-xs text-ink-400">{lead.applicant_nin}</p>
                        </div>
                      </div>
                    </td>
                    <td class="px-2 py-3 text-ink-500 dark:text-ink-300">{lead.source_label}</td>
                    <td class="px-2 py-3 text-ink-500 dark:text-ink-300">
                      {lead.cooperative_name ?? '-'}
                    </td>
                    <td class="px-2 py-3 text-sm text-ink-500 dark:text-ink-300">
                      {lead.branch_name}
                    </td>
                    <td class="px-2 py-3">
                      <Badge label={meta.label} color={meta.color} />
                    </td>
                    <td class="px-2 py-3 text-right font-semibold text-ink-700 dark:text-ink-50">
                      {formatUgx(lead.amount_requested)}
                    </td>
                    <td class="px-5 py-3 text-sm text-ink-500 dark:text-ink-300">
                      {lead.created_at.slice(0, 10)}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
          <div class="flex items-center justify-between border-t border-ink-100 px-5 py-3 text-xs text-ink-400 dark:border-ink-700">
            <span>
              Page {page} of {totalPages} · {totalCount} results
            </span>
            <div class="flex gap-2">
              <a
                href={page > 1 ? pageHref(page - 1) : undefined}
                aria-disabled={page <= 1}
                class={`rounded-pill border border-ink-200 px-3 py-1.5 dark:border-ink-700 ${
                  page <= 1
                    ? 'pointer-events-none opacity-50'
                    : 'hover:bg-ink-50 dark:hover:bg-ink-800'
                }`}
              >
                Previous
              </a>
              <a
                href={page < totalPages ? pageHref(page + 1) : undefined}
                aria-disabled={page >= totalPages}
                class={`rounded-pill border border-ink-200 px-3 py-1.5 dark:border-ink-700 ${
                  page >= totalPages
                    ? 'pointer-events-none opacity-50'
                    : 'hover:bg-ink-50 dark:hover:bg-ink-800'
                }`}
              >
                Next
              </a>
            </div>
          </div>
        </div>
      </div>
    )
  }
</AppLayout>
