---
import '../shared/global.css';
import Sidebar from './Sidebar.astro';
import Topbar from './Topbar.astro';
import ThemeScript from './ThemeScript.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const { user } = Astro.locals;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} · Cente Leads</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <ThemeScript />
  </head>
  <body>
    <div class="grid min-h-screen grid-cols-[260px_1fr]">
      <div class="sticky top-0 h-screen">
        <Sidebar role={user.role} userName={user.full_name} />
      </div>
      <div class="flex min-w-0 flex-col">
        <Topbar
          title={title}
          branchLabel={user.permissions.includes('view_all_branches')
            ? 'Head Office · All branches'
            : (user.branch_name ?? 'Branch scope')}
        />
        <main class="flex-1 bg-ink-50/40 p-8 dark:bg-ink-900">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
