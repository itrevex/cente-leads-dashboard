---
import { navForPermissions, withNavCounts } from './nav';
import type { DashboardRole } from '../shared/types';
import SidebarNav from './SidebarNav';
import { getStatusCounts } from '../domains/leads/api';
import { ApiError } from '../shared/api-client';
import { activeCount } from '../shared/lead-presentation';
import { getPendingLeaders } from '../domains/cooperatives/api';

interface Props {
  role: DashboardRole;
  userName: string;
}
const { role, userName } = Astro.props;
const { user, accessToken } = Astro.locals;
let sections = navForPermissions(user.permissions);
const currentPath = Astro.url.pathname;

const navIds = new Set(sections.flatMap((section) => section.items.map((item) => item.id)));

if (navIds.has('leads') || navIds.has('queue-mine')) {
  try {
    const myLeadsFilter = user.can_be_reviewing_officer
      ? { reviewing_officer: user.id }
      : { branch: user.branch ?? undefined };
    const [allCounts, mineCounts] = await Promise.all([
      navIds.has('leads') ? getStatusCounts(accessToken) : Promise.resolve(null),
      navIds.has('queue-mine')
        ? getStatusCounts(accessToken, myLeadsFilter)
        : Promise.resolve(null),
    ]);
    const countsById: Record<string, number> = {};
    if (allCounts) countsById.leads = activeCount(allCounts.by_status, allCounts.all);
    if (mineCounts) countsById['queue-mine'] = activeCount(mineCounts.by_status, mineCounts.all);
    sections = withNavCounts(sections, countsById);
  } catch (err) {
    if (!(err instanceof ApiError && err.status === 403)) {
      throw err;
    }
  }
}
if (navIds.has('cooperatives') && user.permissions.includes('approve_leaders')) {
  try {
    const pendingCount = (await getPendingLeaders(accessToken)).length;
    if (pendingCount > 0) {
      sections = withNavCounts(sections, { cooperatives: pendingCount });
    }
  } catch (err) {
    if (!(err instanceof ApiError && err.status === 403)) throw err;
  }
}
const initials = userName
  .split(' ')
  .map((part) => part[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();
---

<aside
  class="flex h-full flex-col border-r border-ink-100 bg-white dark:border-ink-700 dark:bg-ink-800"
>
  <div
    class="flex h-16 shrink-0 items-center gap-2.5 border-b border-ink-100 px-5 dark:border-ink-700"
  >
    <img src="/cente-leads-icon.png" alt="Cente Leads" class="h-9 w-9 rounded-[10px]" />
    <div class="flex flex-col">
      <strong
        class="text-[15px] font-bold leading-none text-cente-blue-600 dark:text-cente-blue-300"
        >Cente Leads</strong
      >
      <span
        class="mt-1 text-[10px] font-semibold uppercase leading-none tracking-[0.12em] text-ink-400"
        >Centenary Bank</span
      >
    </div>
  </div>

  <div class="px-5 pt-2 pb-1">
    <span class="text-[11px] font-semibold uppercase tracking-[0.12em] text-ink-400"
      >Operations Dashboard</span
    >
  </div>

  <div class="flex-1 overflow-y-auto px-3 py-2">
    <SidebarNav sections={sections} currentPath={currentPath} client:load />
  </div>

  <div class="flex items-center gap-2.5 border-t border-ink-100 px-4 py-4 dark:border-ink-700">
    <span
      class="flex h-[34px] w-[34px] shrink-0 items-center justify-center rounded-full bg-cente-blue-600 text-xs font-bold text-white"
    >
      {initials}
    </span>
    <div class="min-w-0 flex-1 leading-tight">
      <p class="truncate text-[13px] font-semibold text-ink-700 dark:text-ink-50">{userName}</p>
      <p class="truncate text-[11.5px] text-ink-400">{role.replace('_', ' ')}</p>
    </div>
  </div>
  <form method="post" action="/api/auth/logout" id="logout-form" class="px-4 pb-4">
    <button
      type="submit"
      class="w-full rounded-pill border border-ink-200 px-4 py-2 text-sm text-ink-600 transition hover:bg-ink-50 dark:border-ink-700 dark:text-ink-200 dark:hover:bg-ink-800"
    >
      Log out
    </button>
  </form>
</aside>

<script>
  const form = document.getElementById('logout-form');
  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/login';
  });
</script>
